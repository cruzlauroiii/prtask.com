@page "/"

<h1>version-913142fd943640d2</h1>

<div class="studio-viewport">
    <div class="studio-status">@Status</div>
    <div class="studio-registers">
        <pre>@RegisterDump</pre>
    </div>
    <div class="studio-output">
        <pre>@Output</pre>
    </div>
</div>

<div class="studio-controls">
    <button class="btn" @onclick="RunEntry">Run</button>
</div>

@code {
    private string Status = "Ready";
    private string RegisterDump = string.Empty;
    private string Output = string.Empty;

    private void RunEntry()
    {
        Status = "Running...";
        try
        {
            PrTask.Studio.RobloxStudioBeta.Entry();
            Status = "Completed";
            Output = "Entry point executed successfully in browser via WASM";
            RegisterDump = "Execution complete";
            RegisterDump = "Execution complete";
            RegisterDump = "Execution complete";
            RegisterDump = "Execution complete";
            RegisterDump = "Execution complete";
            RegisterDump = "Execution complete";
        }
        catch (System.Exception Ex)
        {
            Status = "Error";
            Output = Ex.Message;
        }
    }
}
