            </tr>
            <tr>
                <td>prtask-theme</td>
                <td>PrTask</td>
                <td>@Localizer["CookiePolicyThemePurpose"]</td>
                <td>@Localizer["CookiePolicyDuration1Year"]</td>
                <td>@Localizer["CookiePolicyCategoryFunctional"]</td>
            </tr>
            <tr>
