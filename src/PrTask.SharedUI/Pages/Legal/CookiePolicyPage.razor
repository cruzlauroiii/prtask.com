                <td>@Localizer["CookiePolicyGaPurpose"]</td>
                <td>@Localizer["CookiePolicyDuration2Years"]</td>
                <td>@Localizer["CookiePolicyCategoryAnalytics"]</td>
            </tr>
            <tr>
                <td>_gid</td>
                <td>@Localizer["SettingsConnectedGoogle"]</td>
                <td>@Localizer["CookiePolicyGidPurpose"]</td>
                <td>@Localizer["CookiePolicyDuration24Hours"]</td>
                <td>@Localizer["CookiePolicyCategoryAnalytics"]</td>
            </tr>
        </tbody>
    </table>
