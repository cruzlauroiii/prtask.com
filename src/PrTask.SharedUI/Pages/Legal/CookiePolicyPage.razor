@page "/legal/cookie-policy"
@inject IStringLocalizer<PrTask.SharedUI.Resources.SharedResource> Localizer
<h1>@Localizer["CookiePolicyPageHeading"]</h1>
<p>@Localizer["CookiePolicyLastUpdated"]</p>
<p>@Localizer["CookiePolicyIntroduction"]</p>
<h2>1. @Localizer["CookiePolicyWhatAreHeading"]</h2>
<p>@Localizer["CookiePolicyWhatAreDescription"]</p>
<h2>2. @Localizer["CookiePolicyEssentialHeading"]</h2>
