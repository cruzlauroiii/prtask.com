        </div>
        <div class="burger-cat">
            <input type="checkbox" id="@NavConstants.BmLegalCatId" class="bm-check" aria-hidden="true" />
            <label for="@NavConstants.BmLegalCatId" class="bm-label">@L["CategoryLegal"]</label>
            <div class="bm-links">
                <a href="@NavConstants.HrefTerms">@L["TermsLabel"]</a>
                <a href="@NavConstants.HrefPrivacy">@L["PrivacyLabel"]</a>
                <a href="@NavConstants.HrefRefund">@L["RefundLabel"]</a>
                <a href="@NavConstants.HrefAcceptableUse">@L["AcceptableUseLabel"]</a>
                <a href="@NavConstants.HrefCookiePolicy">@L["CookiePolicyLabel"]</a>
                <a href="@NavConstants.HrefLicenses">@L["LicensesLabel"]</a>
                <a href="@NavConstants.HrefAccessibility">@L["AccessibilityLabel"]</a>
