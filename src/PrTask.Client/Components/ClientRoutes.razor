<Router AppAssembly="typeof(ClientRoutes).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(ClientLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(ClientLayout)">
            <h1>Page Not Found</h1>
            <p>The page you requested could not be found.</p>
        </LayoutView>
    </NotFound>
</Router>
